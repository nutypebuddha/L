#!/bin/sh
# armv7a-linux-androideabi cross-compile wrapper for aarch64-host running the
# NDK's x86_64 clang under qemu-x86_64.
#
# qemu-user cannot handle clang's nested exec of a second cc1 process
# (needed when compiling .S/.s assembler-with-cpp inputs): the driver
# resolves the compiler via /proc/self/exe which under qemu points at
# qemu-x86_64, so the child exec fails with "No such file or directory".
#
# Fix: when the invocation compiles a single .S/.s source to an object,
# split it into two top-level qemu calls we control:
#   1. clang -E  (preprocess) -> temp .s
#   2. clang -c  (assemble the already-preprocessed .s)
# Each is its own top-level qemu process, so no nested exec occurs.

NDK=/tmp/android-sdk/ndk/25.0.8775105/toolchains/llvm/prebuilt/linux-x86_64/bin/clang-14
QEMU="qemu-x86_64 -L /tmp/x86_64-sysroot"
TARGET=--target=armv7a-linux-androideabi24

run() { exec $QEMU $NDK $TARGET -fuse-ld=bfd "$@"; }

# Detect a compile-to-object of a single assembler source.
src=""; out=""; is_compile=0; prev=""
for a in "$@"; do
  case "$a" in
    -c) is_compile=1 ;;
  esac
  case "$prev" in
    -o) out="$a" ;;
  esac
  case "$a" in
    *.S|*.s) src="$a" ;;
  esac
  prev="$a"
done

if [ "$is_compile" = 1 ] && [ -n "$src" ] && [ -n "$out" ]; then
  # Rebuild the arg list without the source and without -c/-o pair,
  # keeping all flags (defines, includes, target-features, etc.).
  flags=""; skip=0
  for a in "$@"; do
    if [ "$skip" = 1 ]; then skip=0; continue; fi
    case "$a" in
      -c) continue ;;
      -o) skip=1; continue ;;
      "$src") continue ;;
      *) flags="$flags $a" ;;
    esac
  done
  tmp="${out%.o}.pp.s"
  # Step 1: preprocess (assembler-with-cpp) as a top-level process.
  $QEMU $NDK $TARGET -fuse-ld=bfd $flags -E -x assembler-with-cpp "$src" -o "$tmp" || exit $?
  # Step 2: assemble the preprocessed output as a top-level process.
  $QEMU $NDK $TARGET -fuse-ld=bfd $flags -c -x assembler "$tmp" -o "$out"
  rc=$?
  rm -f "$tmp"
  exit $rc
fi

run "$@"
